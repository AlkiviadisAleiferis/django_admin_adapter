COMPOSE_FILE=compose.yaml
COMPOSE_PROJECT_NAME=django_admin_adapter
# % --------------------------------------------------------------------------------------------
PRODUCTION_SERVER_IP=127.0.0.1
DEBUG=true
PROFILE=development
# ENV vars for system-container UID mapping
# in debug mode UID = 1000 mos tprobably
# in production a system user with < 1000 is used
DOCKER_USER=salpix
DOCKER_USER_ID=1000
INIT_USERS="[('pilot', 'Chumbius', 'Kius', 'Management')]"


# % --------------------------------------------------------------------------------------------
# % --------------------------- ENV VARS FOR BASIC PROJECT STRUCTURE ---------------------------
PROJECT_NAME=django_admin_adapter
PROJECT_BASE_DIR=/opt/${PROJECT_NAME} # /opt/django_admin_adapter
LOGGIN_BASE_DIR=/var/log
CACHE_BASE_DIR=/var/cache



# % ----------------------------------------------------------------
# % --------------------------- DATABASE ---------------------------
# DB (database)
POSTGRES_DB=${PROJECT_NAME}
POSTGRES_USER=${PROJECT_NAME}_admin
POSTGRES_PASSWORD=1234
PGDATA=/var/lib/postgresql/data
DUMP_DIR=/opt



# % -------------------------------------------------------------
# % --------------------------- REDIS ---------------------------
#
# these data must agree with
# `docker/redis/users.acl` and `redis.conf` OR
# `docker/production/redis/users.acl` and `redis.conf`
REDIS_USER=username
REDIS_PASSWORD=1234



# % ---------------------------------------------------------------
# % --------------------------- BACKEND ---------------------------
#
BACKEND_BASE_DIR=${PROJECT_BASE_DIR}/backend



# % -------------------------------------------------------------------------------
# % --------------------------- ADMIN ---------------------------
DJANGO_SETTINGS_MODULE=settings



# % ---------------------------------------------------------------
# % --------------------------- ADMIN ---------------------------
#
ADMIN_BASE_DIR=${PROJECT_BASE_DIR}/admin  # /opt/admin_api_adapter/admin

ADMIN_CACHE_DIR=${CACHE_BASE_DIR}/admin

ADMIN_MEDIA_ROOT=${ADMIN_CACHE_DIR}/media
ADMIN_STATIC_ROOT=${ADMIN_CACHE_DIR}/static

# allowed hosts
ADMIN_ALLOWED_HOSTS="127.0.0.1 172.20.0.3 172.20.0.4 172.20.0.7 localhost"
ADMIN_CSRF_TRUSTED_ORIGINS="https://127.0.0.1 https://localhost"


# % ---------------------------------------------------------------------
# % --------------------------- ADMIN API ---------------------------
#
ADMIN_API_BASE_DIR=${PROJECT_BASE_DIR}/admin_api  # /opt/admin_api_adapter/admin_api

ADMIN_API_CACHE_DIR=${CACHE_BASE_DIR}/admin_api

ADMIN_API_MEDIA_ROOT=${ADMIN_CACHE_DIR}/media # same as admin
ADMIN_API_STATIC_ROOT=${ADMIN_API_CACHE_DIR}/static # same as admin


# allowed hosts
ADMIN_API_ALLOWED_HOSTS="127.0.0.1 172.20.0.3 172.20.0.4 172.20.0.7 localhost"
ADMIN_API_CSRF_TRUSTED_ORIGINS="https://127.0.0.1 https://localhost"
ADMIN_API_CORS_ALLOWED_ORIGINS="http://localhost:3000 http://127.0.0.1:3000"



# % -----------------------------------------------------------------------
# % --------------------------- NETWORK CONFIGS ---------------------------
#
# SERVICES (CONTAINERS) LOCAL IPs
#
# COMMON
COMMON_SUBNET=172.20.0.0/16
# % ------------------------
DB_IP=172.20.0.3
DB_PORT=5432
# % ------------------------
REDIS_IP=172.20.0.4
REDIS_PORT=6379
# % ------------------------
ADMIN_IP=172.20.0.5
ADMIN_PORT=8000
# % ------------------------
ADMIN_API_IP=172.20.0.9
ADMIN_API_PORT=8000
